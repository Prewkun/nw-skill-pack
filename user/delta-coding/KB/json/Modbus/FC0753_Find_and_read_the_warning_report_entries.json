{
  "code": 753,
  "title": "Find and read the warning report entries",
  "protocol": "Modbus",
  "category": "Reports",
  "description": "Use function code #753 with 0x6A to read the content of the warning report. Modbus (Hex) Tool 1 / Tool 2 common status R/W 6A Current No. of warning report entries R",
  "request_fields": [
    {
      "register": "C8",
      "field": "Function code",
      "description": "753"
    },
    {
      "register": "C9",
      "field": "Version number",
      "description": "0"
    },
    {
      "register": "CA",
      "field": "Warning report ID",
      "description": "1 to 60000"
    },
    {
      "register": "CB to CD",
      "field": "Reserved",
      "description": "-"
    },
    {
      "register": "CE",
      "field": "Request to send command",
      "description": "1 (to be filled in last )"
    }
  ],
  "return_fields": [
    {
      "register": "CF",
      "field": "Function code",
      "description": "753"
    },
    {
      "register": "D0",
      "field": "Status",
      "description": "1: OK; 2: NOK"
    },
    {
      "register": "D1",
      "field": "Error code",
      "description": "-"
    }
  ],
  "error_codes": {},
  "notes": "0x5001 - 0x5999: Tool 1 operation warning (WN); 0x6000 - 0x6999: Tool 2 operation warning (WN)"
}