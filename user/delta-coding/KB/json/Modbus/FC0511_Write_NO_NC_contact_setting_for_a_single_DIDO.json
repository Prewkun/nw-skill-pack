{
  "code": 511,
  "title": "Write NO / NC contact setting for a single DI/DO",
  "protocol": "Modbus",
  "category": "Controller",
  "description": "Use function code #511 to set a single DI/DO as an NO / NC contact .",
  "request_fields": [
    {
      "register": "C8",
      "field": "Function code",
      "description": "511"
    },
    {
      "register": "C9",
      "field": "Version number",
      "description": "0"
    },
    {
      "register": "CA",
      "field": "Tool 1 / Tool 2",
      "description": "0: Tool 1; 1: Tool 2"
    },
    {
      "register": "CB",
      "field": "DO / DI",
      "description": "0: DO; 1: DI"
    },
    {
      "register": "CC",
      "field": "Corresponding bit of DO / DI",
      "description": "0 to 7"
    },
    {
      "register": "CD",
      "field": "NO / NC",
      "description": "0: NO  (normally open )"
    },
    {
      "register": "CE",
      "field": "Request to send command",
      "description": "1 (to be filled in last )"
    }
  ],
  "return_fields": [
    {
      "register": "CF",
      "field": "Function code",
      "description": "511"
    },
    {
      "register": "D0",
      "field": "Status",
      "description": "1: OK; 2: NOK"
    },
    {
      "register": "D1",
      "field": "Error code",
      "description": "-"
    }
  ],
  "error_codes": {},
  "notes": ""
}