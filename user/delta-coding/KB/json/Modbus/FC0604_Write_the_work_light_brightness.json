{
  "code": 604,
  "title": "Write the work light brightness",
  "protocol": "Modbus",
  "category": "Tool",
  "description": "Use function code #604 to set the work light brightness of the tool.",
  "request_fields": [
    {
      "register": "C8",
      "field": "Function code",
      "description": "604"
    },
    {
      "register": "C9",
      "field": "Version number",
      "description": "0"
    },
    {
      "register": "CA",
      "field": "Tool 1 / Tool 2",
      "description": "0: Tool 1; 1: Tool 2"
    },
    {
      "register": "CB",
      "field": "Brightness",
      "description": "0 to 50"
    },
    {
      "register": "CC, CD",
      "field": "Reserved",
      "description": "-"
    },
    {
      "register": "CE",
      "field": "Request to send command",
      "description": "1 (to be filled in last )"
    }
  ],
  "return_fields": [
    {
      "register": "CF",
      "field": "Function code",
      "description": "604"
    },
    {
      "register": "D0",
      "field": "Status",
      "description": "1: OK; 2: NOK"
    },
    {
      "register": "D1",
      "field": "Error code",
      "description": "-"
    }
  ],
  "error_codes": {
    "1": "Tool 1 / Tool 2 — Must be 0 or 1",
    "2": "Brightness — Exceeds the range of 0 to 50"
  },
  "notes": ""
}